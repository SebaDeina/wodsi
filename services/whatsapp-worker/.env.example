# Firebase Admin (descargá la JSON desde Firebase Console → Cuentas de servicio)
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccount.json
FIREBASE_PROJECT_ID=wodsi-47ffb

# Carpeta de sesiones WhatsApp (una por coach)
WWEBJS_AUTH_PATH=./.wwebjs_auth

# Zona horaria para reglas programadas (09:30, etc.)
TZ=America/Argentina/Buenos_Aires

# Intervalos en ms
OUTBOX_POLL_MS=15000
SCHEDULER_POLL_MS=60000

# Opcional: Chrome (macOS/Linux/Windows suelen autodetectarse)
# macOS: /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Windows: C:\Program Files\Google\Chrome\Application\chrome.exe
# PUPPETEER_EXECUTABLE_PATH=
