{
  "name": "wodsi",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "superstatic dist --config superstatic.json --port ${PORT:-8080} --host 0.0.0.0",
    "preview": "vite preview",
    "deploy:rules": "firebase deploy --only firestore:rules",
    "deploy:hosting": "npm run build && firebase deploy --only hosting,firestore:rules",
    "whatsapp:install": "npm install --prefix services/whatsapp-worker",
    "whatsapp:dev": "npm run dev --prefix services/whatsapp-worker",
    "whatsapp:start": "npm run start --prefix services/whatsapp-worker",
    "billing:install": "npm install --prefix services/billing-api",
    "billing:dev": "npm run dev --prefix services/billing-api",
    "billing:start": "npm run start --prefix services/billing-api",
    "billing:create-plans": "node services/billing-api/scripts/create-mp-plans.mjs",
    "admin:setup-firestore": "node services/billing-api/scripts/setup-admin-firestore.mjs",
    "docker:up": "docker compose up -d --build",
    "docker:logs": "docker compose logs -f",
    "docker:down": "docker compose down"
  },
  "dependencies": {
    "firebase": "^12.13.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "superstatic": "^9.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "vite": "^5.4.8"
  }
}
